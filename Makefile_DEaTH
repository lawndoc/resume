ifeq ($(shell uname), Darwin)
CC=clang
CXX=clang++
AR=ar
endif

.PHONY : all
all : release

release : PDFGitPolyglot.pdf
	rm resume_death*[!.tex]
	rm *.aux
	rm *.log
	rm *.out
	rm -rf __pycache__
	mv PDFGitPolyglot.pdf CJ_May_Resume_DEaTH.pdf

.PHONY : local-clean
local-clean :
	rm -f PDFGitPolyglot.pdf resume_death.pdf resume_death.log resume_death.aux *~

.PHONY : clean
clean : git-submodule local-clean
	$(MAKE) -C git clean

.PHONY : git-submodule
git-submodule :
	git submodule init
	git submodule update --recursive

git/configure : | git-submodule
	$(MAKE) -C git configure
	cd git && ./configure

git/git : | git/configure
	$(MAKE) CC=$(CC) CXX=$(CXX) AR=$(AR) -C git

resume_death.pdf : resume_death.tex
	pdflatex resume_death
	pdflatex resume_death

%_small.jpg : %.jpg
	convert $< -define jpeg:extent=63kb $@

%_injected.pdf %.pdf.block_offsets : %.pdf fix_oversize_pdf.py
	./fix_oversize_pdf.py $*.pdf $*_injected.pdf

PDFGitPolyglot.pdf : resume_death_injected.pdf resume_death.pdf.block_offsets git/git update_deflate_headers.py
	./make_polyglot.sh resume_death_injected.pdf $@
	mv $@ $@.polyglot
	./update_deflate_headers.py $@.polyglot $@ resume_death.pdf.block_offsets
	rm $@.polyglot
